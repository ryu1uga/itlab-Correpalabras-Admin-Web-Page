            },
            {
                "pages":[
                    {"_id":1438,"storyId":22,"languageId":3,"textcontent":"Titum nin, mesapim kachkan tinyay ukupi, nispa.","countWords":7,"updatedAt":"2020-09-09T18:09:56.74","pageNOrder":1},
                    {"_id":1439,"storyId":22,"languageId":3,"textcontent":"Maskantaqmi chukun hinallataq guantesnin ukupi.","countWords":5,"updatedAt":"2020-09-09T18:09:56.74","pageNOrder":2},
                    {"_id":1440,"storyId":22,"languageId":3,"textcontent":"¿Icha pakasqa kachkan cuadernunkuna utaq librunkuna ukupi?","countWords":7,"updatedAt":"2020-09-09T18:09:56.74","pageNOrder":3},
                    {"_id":1441,"storyId":22,"languageId":3,"textcontent":"Tazan utaq platun ukupicha kachkan.","countWords":5,"updatedAt":"2020-09-09T18:09:56.74","pageNOrder":4},
                    {"_id":1442,"storyId":22,"languageId":3,"textcontent":"Chaynapim, maypi churasqanta yuyarirqun.","countWords":4,"updatedAt":"2020-09-09T18:09:56.74","pageNOrder":5},
                    {"_id":1443,"storyId":22,"languageId":3,"textcontent":"Titum yuyaymanakun: “Ordenadum kanay hinallataq mana qunqaq”.","countWords":7,"updatedAt":"2020-09-09T18:09:56.74","pageNOrder":6},
                    {"_id":1444,"storyId":22,"languageId":3,"textcontent":"¡Qillqakuna ñawinchaymi kusichiwan!","countWords":3,"updatedAt":"2020-09-09T18:09:56.74","pageNOrder":7}
